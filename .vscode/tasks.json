{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build raylib game",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-I${workspaceFolder}/include",
                "-ID:/Raylib/include",
                "-LD:/Raylib/lib",
                "${workspaceFolder}/src/main.cpp",
                "-o",
                "${workspaceFolder}/game.exe",
                "-lraylibdll",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-static-libgcc",
                "-static-libstdc++",
                "-Wl,--subsystem=windows"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            }
        }
    ]
}